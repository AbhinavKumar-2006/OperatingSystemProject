#include "scheduler.h"
#include <time.h>

void lottery(Process p[], int n) {
    srand(time(NULL));

    int time = 0, completed = 0;
    int gantt[100][3], g = 0;

    while(completed < n) {
        int totalTickets = 0;

        for(int i = 0; i < n; i++) {
            if(p[i].arrival <= time && p[i].remaining > 0)
                totalTickets += p[i].tickets;
        }

        if(totalTickets == 0) {
            time++;
            continue;
        }

        int winner = rand() % totalTickets;
        int sum = 0;

        for(int i = 0; i < n; i++) {
            if(p[i].arrival <= time && p[i].remaining > 0) {
                sum += p[i].tickets;

                if(sum > winner) {
                    gantt[g][0] = p[i].id;
                    gantt[g][1] = time;

                    time++;
                    p[i].remaining--;

                    gantt[g][2] = time;
                    g++;

                    if(p[i].remaining == 0) {
                        p[i].completion = time;
                        completed++;
                    }
                    break;
                }
            }
        }
    }

    printGanttChart(gantt, g);
    calculateMetrics(p, n);
}

#include "scheduler.h"

void edf(Process p[], int n) {
    int time = 0, completed = 0;
    int gantt[100][3], g = 0;

    while(completed < n) {
        int minDeadline = 9999;
        int idx = -1;

        for(int i = 0; i < n; i++) {
            if(p[i].arrival <= time && p[i].remaining > 0) {
                if(p[i].deadline < minDeadline) {
                    minDeadline = p[i].deadline;
                    idx = i;
                }
            }
        }

        if(idx == -1) {
            time++;
            continue;
        }

        gantt[g][0] = p[idx].id;
        gantt[g][1] = time;

        time++;
        p[idx].remaining--;

        gantt[g][2] = time;
        g++;

        if(p[idx].remaining == 0) {
            p[idx].completion = time;
            completed++;
        }
    }

    printGanttChart(gantt, g);
    calculateMetrics(p, n);
}

